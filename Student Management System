#include <stdio.h>
#include <stdlib.h>

struct student
{
    int roll;
    char name[30];
    float marks;
};

void add();
void display();
void search();
void update();
void del();

int main()
{
    int ch;

    while(1)
    {
        printf("\n===== Student Management System =====");
        printf("\n1. Add Student");
        printf("\n2. Display Students");
        printf("\n3. Search Student");
        printf("\n4. Update Student");
        printf("\n5. Delete Student");
        printf("\n6. Exit");
        printf("\nEnter your choice: ");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1:
                add();
                break;

            case 2:
                display();
                break;

            case 3:
                search();
                break;

            case 4:
                update();
                break;

            case 5:
                del();
                break;

            case 6:
                exit(0);

            default:
                printf("Invalid Choice");
        }
    }

    return 0;
}

void add()
{
    FILE *fp;
    struct student s;

    fp=fopen("student.dat","ab");

    printf("Enter Roll No: ");
    scanf("%d",&s.roll);

    printf("Enter Name: ");
    scanf("%s",s.name);

    printf("Enter Marks: ");
    scanf("%f",&s.marks);

    fwrite(&s,sizeof(s),1,fp);

    fclose(fp);

    printf("Record Added Successfully");
}

void display()
{
    FILE *fp;
    struct student s;

    fp=fopen("student.dat","rb");

    if(fp==NULL)
    {
        printf("No Records Found");
        return;
    }

    printf("\nRoll\tName\tMarks\n");

    while(fread(&s,sizeof(s),1,fp))
    {
        printf("%d\t%s\t%.2f\n",s.roll,s.name,s.marks);
    }

    fclose(fp);
}

void search()
{
    FILE *fp;
    struct student s;
    int roll, found=0;

    fp=fopen("student.dat","rb");

    printf("Enter Roll Number: ");
    scanf("%d",&roll);

    while(fread(&s,sizeof(s),1,fp))
    {
        if(s.roll==roll)
        {
            printf("\nRoll : %d",s.roll);
            printf("\nName : %s",s.name);
            printf("\nMarks : %.2f",s.marks);
            found=1;
            break;
        }
    }

    if(found==0)
        printf("Record Not Found");

    fclose(fp);
}

void update()
{
    FILE *fp;
    struct student s;
    int roll, found=0;

    fp=fopen("student.dat","rb+");

    printf("Enter Roll Number to Update: ");
    scanf("%d",&roll);

    while(fread(&s,sizeof(s),1,fp))
    {
        if(s.roll==roll)
        {
            printf("Enter New Name: ");
            scanf("%s",s.name);

            printf("Enter New Marks: ");
            scanf("%f",&s.marks);

            fseek(fp,-sizeof(s),SEEK_CUR);
            fwrite(&s,sizeof(s),1,fp);

            found=1;
            printf("Record Updated");
            break;
        }
    }

    if(found==0)
        printf("Record Not Found");

    fclose(fp);
}

void del()
{
    FILE *fp,*temp;
    struct student s;
    int roll, found=0;

    fp=fopen("student.dat","rb");
    temp=fopen("temp.dat","wb");

    printf("Enter Roll Number to Delete: ");
    scanf("%d",&roll);

    while(fread(&s,sizeof(s),1,fp))
    {
        if(s.roll==roll)
        {
            found=1;
        }
        else
        {
            fwrite(&s,sizeof(s),1,temp);
        }
    }

    fclose(fp);
    fclose(temp);

    remove("student.dat");
    rename("temp.dat","student.dat");

    if(found)
        printf("Record Deleted");
    else
        printf("Record Not Found");
}
